# ============================================================
# SmartStay AI — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ============================================================

# ── Required ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Passwords for the manager dashboard and super-admin panel.
# Change these before going to production.
MANAGER_PASSWORD=change_me_manager
ADMIN_PASSWORD=change_me_admin

# ── Registration protection ───────────────────────────────────
# Leave empty to allow open registration (good for pilots/demos).
# Set to a secret string to require an invite code on /register.
INVITE_CODE=

# ── Cookie security ───────────────────────────────────────────
# Set to true on Railway (HTTPS). Keep false for local HTTP dev.
SECURE_COOKIES=false

# ── Telegram fallback bot (optional) ─────────────────────────
# Used when a hotel has no own Telegram bot configured.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Database ──────────────────────────────────────────────────
# Default: smartstay.db in the project root (local dev).
#
# RAILWAY PRODUCTION SETUP:
#   1. In Railway dashboard → your service → "Add Volume"
#   2. Mount path: /data
#   3. Set DATABASE_PATH=/data/smartstay.db  ← in Railway env vars
#   Without a volume, the DB resets on every redeploy!
#
DATABASE_PATH=smartstay.db

# ── Cron jobs ─────────────────────────────────────────────────
# Protect the /api/cron/* endpoints with a random secret.
# Pass it as ?secret=XXX when calling the endpoint.
# Leave empty to disable cron endpoints entirely.
CRON_SECRET=

# ── Stripe billing (optional) ────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
# Webhook secret: after running `stripe listen` or registering endpoint in Stripe dashboard
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from Stripe dashboard → Products → Prices
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Stripe webhook endpoint to register:
#   URL: https://your-domain.com/api/stripe/webhook
#   Events: checkout.session.completed, customer.subscription.updated,
#           customer.subscription.deleted, invoice.payment_failed

# ── Railway notes ─────────────────────────────────────────────
# SECURE_COOKIES=true       ← required on Railway (HTTPS)
# PORT is set automatically by Railway — do not set manually.
#
# DAILY DIGEST CRON (Railway Cron Service or external):
#   Schedule: 0 7 * * *  (07:00 UTC = 09:00 Istanbul)
#   Command:  curl -s "$RAILWAY_PUBLIC_DOMAIN/api/cron/daily-digest?secret=$CRON_SECRET"
